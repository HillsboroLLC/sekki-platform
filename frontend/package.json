  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "css:organize": "postcss src/jaspenInterface/Workspace/JaspenWorkspace.css -o src/jaspenInterface/Workspace/JaspenWorkspace.organized.css",
    "css:format": "prettier --write src/jaspenInterface/Workspace/JaspenWorkspace.organized.css",
    "css:organize:pretty": "npm run css:organize && npm run css:format",
    "css:dedupe": "node scripts/css-dedupe.mjs",
    "deploy": "node ./scripts/deploy.mjs",
    "build:deploy": "npm run build && npm run deploy",
    "env:check": "node ./scripts/check-env.mjs",
    "deploy:check": "node ./scripts/check-env.mjs --connect",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "css-declaration-sorter": "^7.3.0",
    "dotenv": "^17.2.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
